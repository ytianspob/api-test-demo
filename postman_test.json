  "item": [
    {
      "name": "Get data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"响应包含url字段\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.url).to.exist;",
              "});",
              "// 测试：验证savedUrl环境变量存在",
              "pm.test(\"savedUrl环境变量存在\", function () {",
              "    var savedUrl = pm.environment.get(\"savedUrl\");",
              "    pm.expect(savedUrl).to.exist;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/get",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "get"
          ]
        },
        "description": "This is a GET request and it is used to \"get\" data from an endpoint. There is no request body for a GET request, but you can use query parameters to help specify the resource you want data on (e.g., in this request, we have `id=1`).\n\nA successful GET response will have a `200 OK` status, and should include some kind of response body - for example, HTML web content or JSON data."
      },
      "response": []
    },
    {
      "name": "Post data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 测试1：状态码是200",
              "pm.test(\"状态码是200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// 测试2：验证服务器收到了正确的name",
              "pm.test(\"name字段是张三\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.json.name).to.eql(\"张三\");",
              "});",
              "",
              "// 测试3：验证服务器收到了正确的role",
              "pm.test(\"role字段是tester\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.json.role).to.eql(\"tester\");",
              "});",
              "// 把响应里的url字段存入环境变量",
              "var jsonData = pm.response.json();",
              "pm.environment.set(\"savedUrl\", jsonData.url);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
